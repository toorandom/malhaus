# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.

# Flask secret key — generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
MALHAUS_SECRET_KEY=change_me

# ── LLM provider ─────────────────────────────────────────────────────────────
# Uncomment exactly one block below.

# -- Google Gemini (default) --------------------------------------------------
MALHAUS_LLM_PROVIDER=gemini
MALHAUS_LLM_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
MALHAUS_MODEL_STRINGS=gemini-2.5-flash
MALHAUS_MODEL_VERDICT=gemini-2.5-pro
MALHAUS_LLM_ENDPOINT=

# -- OpenAI -------------------------------------------------------------------
# MALHAUS_LLM_PROVIDER=openai
# MALHAUS_LLM_API_KEY=sk-...
# MALHAUS_MODEL_STRINGS=gpt-4o-mini
# MALHAUS_MODEL_VERDICT=gpt-4o
# MALHAUS_LLM_ENDPOINT=

# -- Azure AI Foundry (Azure OpenAI) — API key --------------------------------
# Deploy your models in Azure AI Foundry, then copy the endpoint and key from
# the deployment page: AI Foundry → your project → Deployments → <model> → Consume
#
# MALHAUS_LLM_PROVIDER=azure
# MALHAUS_LLM_API_KEY=<azure-api-key>
# MALHAUS_LLM_ENDPOINT=https://<resource-name>.openai.azure.com/
# MALHAUS_MODEL_STRINGS=gpt-4o-mini   # must match your deployment name exactly
# MALHAUS_MODEL_VERDICT=gpt-4o        # must match your deployment name exactly

# -- Azure AI Foundry — Entra ID / RBAC (no API key) -------------------------
# Use Managed Identity or Service Principal instead of an API key.
# Grant the identity "Cognitive Services OpenAI User" RBAC on the resource.
# Requires: azure-identity (already in requirements.txt)
#
# Azure AI Foundry exposes two endpoint styles — use the one matching your setup:
#
#   Style A — standard Azure OpenAI endpoint (AzureChatOpenAI):
#     MALHAUS_LLM_PROVIDER=azure
#     MALHAUS_LLM_ENDPOINT=https://<resource-name>.openai.azure.com/
#
#   Style B — AI Foundry /openai/v1/ endpoint (OpenAI-compatible client):
#     MALHAUS_LLM_PROVIDER=openai
#     MALHAUS_LLM_ENDPOINT=https://<resource-name>.openai.azure.com/openai/v1/
#
# For both styles, set:
# MALHAUS_AZURE_USE_ENTRA_ID=1
# MALHAUS_MODEL_STRINGS=<your-deployment-name>   # e.g. gpt-4.1-mini
# MALHAUS_MODEL_VERDICT=<your-deployment-name>   # e.g. gpt-4.1
#
# Managed Identity (running inside Azure — no extra credentials needed):
# MALHAUS_LLM_PROVIDER=openai
# MALHAUS_AZURE_USE_ENTRA_ID=1
# MALHAUS_LLM_ENDPOINT=https://<resource-name>.openai.azure.com/openai/v1/
# MALHAUS_MODEL_STRINGS=<deployment-name>
# MALHAUS_MODEL_VERDICT=<deployment-name>
#
# Service Principal (anywhere outside Azure):
# MALHAUS_LLM_PROVIDER=openai
# MALHAUS_AZURE_USE_ENTRA_ID=1
# MALHAUS_LLM_ENDPOINT=https://<resource-name>.openai.azure.com/openai/v1/
# MALHAUS_MODEL_STRINGS=<deployment-name>
# MALHAUS_MODEL_VERDICT=<deployment-name>
# AZURE_TENANT_ID=<your-tenant-id>
# AZURE_CLIENT_ID=<your-app-registration-client-id>
# AZURE_CLIENT_SECRET=<your-client-secret>

# -- Any OpenAI-compatible server (Ollama, vLLM, LM Studio, LocalAI, etc.) ---
# Works with any server that exposes an OpenAI-compatible /v1 endpoint.
#
# MALHAUS_LLM_PROVIDER=openai
# MALHAUS_LLM_API_KEY=not-needed      # some servers require a dummy value
# MALHAUS_LLM_ENDPOINT=http://host.docker.internal:11434/v1   # Ollama example
# MALHAUS_MODEL_STRINGS=llama3.1:8b
# MALHAUS_MODEL_VERDICT=llama3.1:70b

# -- Anthropic Claude ---------------------------------------------------------
# MALHAUS_LLM_PROVIDER=claude
# MALHAUS_LLM_API_KEY=sk-ant-...
# MALHAUS_MODEL_STRINGS=claude-haiku-4-5-20251001
# MALHAUS_MODEL_VERDICT=claude-sonnet-4-6
# MALHAUS_LLM_ENDPOINT=

# -- DeepSeek -----------------------------------------------------------------
# MALHAUS_LLM_PROVIDER=deepseek
# MALHAUS_LLM_API_KEY=sk-...
# MALHAUS_MODEL_STRINGS=deepseek-chat
# MALHAUS_MODEL_VERDICT=deepseek-chat
# MALHAUS_LLM_ENDPOINT=   # leave empty for https://api.deepseek.com

# Limits
MALHAUS_MAX_UPLOAD_MB=10
MALHAUS_MAX_PER_HOUR=20
MALHAUS_MAX_CONCURRENT=3
MALHAUS_LLM_TIMEOUT=60

# Set to 1 because nginx handles HTTPS and forwards X-Forwarded-For
MALHAUS_TRUSTED_PROXY=1

# Web UI captcha (1=enabled, 0=disabled — useful for private/internal deployments)
MALHAUS_CAPTCHA_ENABLED=1

# Set to 1 to show raw LLM prompt/output in report pages (dev only)
MALHAUS_LLM_DEBUG_IN_REPORT=0

# Ghidra (optional — requires JDK 21 installed in the container)
# MALHAUS_GHIDRA_DIR=/opt/ghidra
# JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
